# ==========================================
# GLOBAL
# ==========================================
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0

# ==========================================
# GATEWAY
# ==========================================
GATEWAY_PORT=8000

# ==========================================
# FRONTEND
# Use http://localhost:8000 if you run frontend with npm run dev.
# Use http://localhost/api if you use the nginx entrypoint at http://localhost.
# ==========================================
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost:8000

# ==========================================
# AUTH SERVICE
# ==========================================
AUTH_SERVICE_PORT=8001
AUTH_DB_NAME=auth_db
AUTH_DB_USER=postgres
AUTH_DB_PASSWORD=postgres
AUTH_DB_HOST=auth_db
AUTH_DB_PORT=5432
AUTH_DATABASE_URL=postgresql+psycopg2://postgres:postgres@auth_db:5432/auth_db

# ==========================================
# EXPENSE SERVICE
# ==========================================
EXPENSE_SERVICE_PORT=8002
EXPENSE_DB_NAME=expense_db
EXPENSE_DB_USER=postgres
EXPENSE_DB_PASSWORD=postgres
EXPENSE_DB_HOST=expense_db
EXPENSE_DB_PORT=5432
EXPENSE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@expense_db:5432/expense_db

# ==========================================
# LOAN SERVICE
# ==========================================
LOAN_SERVICE_PORT=8003
LOAN_DB_NAME=loan_db
LOAN_DB_USER=postgres
LOAN_DB_PASSWORD=postgres
LOAN_DB_HOST=loan_db
LOAN_DB_PORT=5432
LOAN_DATABASE_URL=postgresql+psycopg2://postgres:postgres@loan_db:5432/loan_db

# ==========================================
# ANALYTICS SERVICE
# ==========================================
ANALYTICS_SERVICE_PORT=8004

# ==========================================
# MULTI-AGENT SERVICE
# ==========================================
AGENT_SERVICE_PORT=8005
MONGODB_URL=mongodb://mongodb:27017
MONGODB_DB_NAME=agent_memory_db

# ==========================================
# NOTIFICATION SERVICE
# ==========================================
NOTIFICATION_SERVICE_PORT=8006
NOTIFICATION_DB_NAME=notification_db
NOTIFICATION_DB_USER=postgres
NOTIFICATION_DB_PASSWORD=postgres
NOTIFICATION_DB_HOST=notification_db
NOTIFICATION_DB_PORT=5432
NOTIFICATION_DATABASE_URL=postgresql+psycopg2://postgres:postgres@notification_db:5432/notification_db

# ==========================================
# JWT / SECURITY
# ==========================================
JWT_SECRET_KEY=change_me_super_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ==========================================
# REDIS
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==========================================
# KAFKA
# ==========================================
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_CLIENT_ID=amma-app

# ==========================================
# MINIO / COLD OBJECT STORAGE
# ==========================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ==========================================
# LLM / OLLAMA
# ==========================================
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

# ==========================================
# OBSERVABILITY
# ==========================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
JAEGER_UI_PORT=16686
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENVIRONMENT=local
LANGFUSE_RELEASE=amma-task3
LANGFUSE_CAPTURE_INPUT_OUTPUT=true
LANGFUSE_MAX_PAYLOAD_CHARS=5000
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=amma-local
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ==========================================
# INTERNAL SERVICE URLS
# ==========================================
AUTH_SERVICE_URL=http://auth_service:8000
EXPENSE_SERVICE_URL=http://expense_service:8000
LOAN_SERVICE_URL=http://loan_service:8000
ANALYTICS_SERVICE_URL=http://analytics_service:8000
MULTI_AGENT_SYSTEM_URL=http://multi_agent_system:8000
NOTIFICATION_SERVICE_URL=http://notification_service:8000
