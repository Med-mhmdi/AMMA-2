# ==========================================
# LANGFUSE / LLM OBSERVABILITY
# ==========================================

# Enable Langfuse tracing for the multi-agent system
LANGFUSE_ENABLED=true

# Get these keys from your Langfuse project settings
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key

# If Langfuse runs directly on your PC:
LANGFUSE_HOST=http://localhost:3000

# If the Agent Service runs inside Docker and Langfuse is another Docker service,
# replace the host with the Langfuse service name, for example:
# LANGFUSE_HOST=http://langfuse-web:3000

# Metadata shown in Langfuse traces
LANGFUSE_ENVIRONMENT=development
LANGFUSE_RELEASE=amma-multi-agent-v1

# Capture prompts and responses in Langfuse.
# For demo/defense: true
# For private production data: false
LANGFUSE_CAPTURE_INPUT_OUTPUT=true

# Limit large payloads before sending them to Langfuse
LANGFUSE_MAX_PAYLOAD_CHARS=4000